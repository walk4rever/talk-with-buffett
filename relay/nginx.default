# air7.fun HTTP
server {
    listen 80;
    server_name air7.fun;

    root /var/www/html;
    index index.html index.htm;

    location / {
        try_files $uri $uri/ =404;
    }
}

# air7.fun HTTPS
server {
    listen 443 ssl;
    server_name air7.fun;

    ssl_certificate /etc/letsencrypt/live/air7.fun/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/air7.fun/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    root /var/www/html;
    index index.html index.htm;

    location / {
        try_files $uri $uri/ =404;
    }
}

# relay.air7.fun HTTPS - path-based routing
server {
    server_name relay.air7.fun;

    client_max_body_size 10m;
    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;

    # ASR relay (talk-with-buffett) -> port 3001
    location /asr/ {
        proxy_pass http://127.0.0.1:3001/asr/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_buffering off;
        chunked_transfer_encoding off;
    }

    # LLM proxy (xiaozhuang) -> port 3002
    location /llm {
        proxy_pass http://127.0.0.1:3002;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_buffering off;
        chunked_transfer_encoding off;
    }

    # Deny all other paths on relay subdomain.
    location / {
        return 404;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/relay.air7.fun/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/relay.air7.fun/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

# relay.air7.fun HTTP -> HTTPS
server {
    if ($host = relay.air7.fun) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    server_name relay.air7.fun;
    return 404; # managed by Certbot
}
