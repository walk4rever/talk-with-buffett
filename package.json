{
  "name": "buffett-tribe",
  "version": "0.34.7",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "eval:retrieval:v2": "node --loader ts-node/esm scripts/eval-retrieval-v2.ts",
    "eval:mvp:benchmark": "node --loader ts-node/esm scripts/eval-mvp-benchmark.ts",
    "eval:mvp:compare": "node --loader ts-node/esm scripts/compare-mvp-benchmark.ts",
    "test:asr": "node scripts/test-volc-asr.mjs",
    "import:13f": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/import-13f.ts",
    "import:13f:range": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/import-13f.ts --from 2024Q1 --to 2025Q4",
    "import:10k": "node --env-file=.env.local ./node_modules/.bin/ts-node --esm --experimentalSpecifierResolution=node scripts/import-10k-xbrl.ts",
    "import:10k:from13f": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/import-10k-from-13f.ts",
    "migrate:company:securities": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/migrate-company-securities.ts",
    "migrate:company:securities:dry": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/migrate-company-securities.ts --dry-run",
    "migrate:person:master": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/migrate-person-to-master.ts",
    "migrate:person:master:dry": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/migrate-person-to-master.ts --dry-run",
    "backfill:security:company-links": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/backfill-security-company-links.ts",
    "backfill:security:company-links:dry": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/backfill-security-company-links.ts --dry-run",
    "backfill:security:table": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/backfill-security-table.ts",
    "backfill:security:table:dry": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/backfill-security-table.ts --dry-run",
    "sync:company-name-map": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/sync-company-name-map.ts",
    "sync:company-name-map:dry": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/sync-company-name-map.ts --dry-run",
    "backfill:names": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/backfill-names.ts",
    "backfill:names:dry": "node --env-file=.env.local ./node_modules/.bin/tsx scripts/backfill-names.ts --dry-run",
    "check:db": "node --env-file=.env.local ./node_modules/.bin/ts-node --esm --experimentalSpecifierResolution=node scripts/check-db.ts",
    "neo4j:smoke": "node --env-file=.env.local ./node_modules/.bin/ts-node --esm --experimentalSpecifierResolution=node scripts/neo4j-smoke-test.ts",
    "neo4j:schema:v2": "node --env-file=.env.local ./node_modules/.bin/ts-node --esm --experimentalSpecifierResolution=node scripts/neo4j-schema-v2.ts",
    "neo4j:schema:v2:reset": "node --env-file=.env.local ./node_modules/.bin/ts-node --esm --experimentalSpecifierResolution=node scripts/neo4j-schema-v2.ts --reset",
    "neo4j:extract": "node --env-file=.env.local ./node_modules/.bin/ts-node --esm --experimentalSpecifierResolution=node scripts/neo4j-extract-triplets.ts",
    "neo4j:extract:test": "node --env-file=.env.local ./node_modules/.bin/ts-node --esm --experimentalSpecifierResolution=node scripts/neo4j-extract-triplets.ts --year 1989 --dry-run",
    "neo4j:extract:recent": "node --env-file=.env.local ./node_modules/.bin/ts-node --esm --experimentalSpecifierResolution=node scripts/neo4j-extract-triplets.ts --from 2021 --to 2025",
    "neo4j:seed:mvp": "node --env-file=.env.local ./node_modules/.bin/ts-node --esm --experimentalSpecifierResolution=node scripts/neo4j-seed-mvp.ts",
    "neo4j:import:2020-2025": "node --env-file=.env.local ./node_modules/.bin/ts-node --esm --experimentalSpecifierResolution=node scripts/neo4j-import-shareholder-range.ts --from 2020 --to 2025 --type shareholder",
    "neo4j:test": "node --env-file=.env.local ./node_modules/.bin/ts-node --esm --experimentalSpecifierResolution=node scripts/test-neo4j-query.ts",
    "retrieval:compare": "node --env-file=.env.local ./node_modules/.bin/ts-node --esm --experimentalSpecifierResolution=node scripts/test-retrieval-compare.ts",
    "neo4j:progress": "node --env-file=.env.local ./node_modules/.bin/ts-node --esm --experimentalSpecifierResolution=node scripts/neo4j-progress.ts",
    "neo4j:progress:partnership": "node --env-file=.env.local ./node_modules/.bin/ts-node --esm --experimentalSpecifierResolution=node scripts/neo4j-progress.ts --type partnership"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "6.19.2",
    "@types/ws": "^8.18.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "fast-xml-parser": "^5.7.3",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "langfuse": "^3.38.20",
    "neo4j-driver": "^6.0.1",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "posthog-js": "^1.363.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.4",
    "uqr": "^0.1.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.60.0",
    "prisma": "6.19.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
