# Database (Supabase / Postgres)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# Auth — NextAuth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Auth — GitHub OAuth (https://github.com/settings/developers)
GITHUB_ID="your-github-client-id"
GITHUB_SECRET="your-github-client-secret"

# Auth — Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_ID="your-google-client-id"
GOOGLE_SECRET="your-google-client-secret"

# AI Configuration — 用于翻译管道和 Deep Dive 分析
# 支持任何 OpenAI 兼容 API（DashScope、MiniMax、OpenAI 等）
AI_API_KEY="your-api-key"
AI_API_BASE_URL="https://coding.dashscope.aliyuncs.com/v1"
AI_MODEL="MiniMax-M2.5"

# Embedding — 可以与 Chat 使用不同的 API 服务
# 火山引擎标准 API（非 coding plan）
EMBEDDING_API_KEY="your-embedding-api-key"
EMBEDDING_API_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
EMBEDDING_MODEL="doubao-embedding-large"

# Speech / ASR — 豆包流式语音识别 v2
# 控制台: https://console.volcengine.com/speech/service/8
# 如果 relay 单独部署在阿里云服务器，前端/Vercel 填这个地址
# Voice relay — 前端直连（绕过 Vercel，减少一跳延迟）
NEXT_PUBLIC_VOICE_RELAY_URL="https://relay.example.com"
# 后端 proxy fallback（Vercel 侧，前端直连不可用时）
VOICE_RELAY_URL="https://relay.example.com"
VOLCENGINE_ASR_APP_ID=""
VOLCENGINE_ASR_ACCESS_TOKEN=""
VOLCENGINE_ASR_CLUSTER="volcengine_streaming"
VOLCENGINE_ASR_RESOURCE_ID="volc.bigasr.sauc.duration"
VOLCENGINE_ASR_WS_URL="wss://openspeech.bytedance.com/api/v2/asr"

# Speech / TTS — 豆包 WebSocket 语音合成
# 控制台: https://console.volcengine.com/speech/service/8
VOLCANO_TTS_APPID=""
VOLCANO_TTS_ACCESS_TOKEN=""
VOLCANO_TTS_SECRET_KEY=""
VOLCANO_TTS_VOICE_TYPE="zh_male_m191_uranus_bigtts"
VOLCANO_TTS_WS_URL="wss://openspeech.bytedance.com/api/v1/tts/ws_binary"

# Analytics — PostHog
NEXT_PUBLIC_POSTHOG_KEY="phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"

# Chat — 每用户每天免费对话次数（默认 30）
FREE_DAILY_CHAT_LIMIT="1000"

# Chat retrieval scope (comma-separated source types)
# Default recommended: shareholder,partnership
CHAT_SOURCE_TYPES="shareholder,partnership"

# Neo4j Aura (GraphRAG)
NEO4J_URI="neo4j+s://xxxx.databases.neo4j.io"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="your-neo4j-password"
